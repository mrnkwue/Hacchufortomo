    const MONTHS = ["1月","2月","3月","4月","5月","6月","7月","8月","9月","10月","11月","12月"];

    function calcOrderQty(dailyRequired, leadTimeDays, orderCycleDays, currentStock) {
      const needed = dailyRequired * (leadTimeDays + orderCycleDays);
      return Math.max(0, Math.ceil(needed - currentStock));
    }

    function StatusBadge({ orderQty, currentStock, optimalStock }) {
      const b = (bg, color, label) => (
        <span style={{ background:bg, color, padding:"2px 10px", borderRadius:20, fontSize:11, fontWeight:700 }}>{label}</span>
      );
      if (optimalStock > 0 && currentStock >= optimalStock) return b("#d1fae5","#065f46","適正");
      if (orderQty > 0 && optimalStock > 0 && currentStock < optimalStock * 0.4) return b("#fee2e2","#991b1b","要発注");
      if (orderQty > 0) return b("#fef3c7","#92400e","発注推奨");
      return b("#f3f4f6","#6b7280","在庫十分");
    }

    function LoadingSpinner() {
      return (
        <div style={{display:"flex",alignItems:"center",justifyContent:"center",height:"60vh",flexDirection:"column",gap:16}}>
          <div style={{width:40,height:40,border:"4px solid #e2e8f0",borderTop:"4px solid #6366f1",borderRadius:"50%",animation:"spin 0.8s linear infinite"}}></div>
          <div style={{fontSize:14,color:"#64748b"}}>データを読み込み中…</div>
          <style>{`@keyframes spin { to { transform: rotate(360deg); } }`}</style>
        </div>
      );
